# Keeps environment matrix (Phase 2.6 §D1).
# Copy to .env.local for local dev. In Vercel, set Production + Preview values per the
# table in docs/phases/phase-2.6-auth-go-live.md. Each var below has a one-line purpose;
# vars marked "LEAVE UNSET IN LOCAL" must be empty/absent in .env.local so the dev paths
# (dev email sender, Inngest dev server) are used instead of live services.

# --- App ---
# Public base URL used to build outbound links (sign-up, reply CTAs). Local: localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database ---
# Postgres connection string. Local: Docker Postgres. Prod: RDS with ?sslmode=require.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/keeps

# --- Clerk (auth) ---
# Server-side secret key for Clerk's backend SDK (auth(), webhook verify). Dev instance locally.
CLERK_SECRET_KEY=
# Publishable key for Clerk's server helpers. Mirrors NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY.
CLERK_PUBLISHABLE_KEY=
# Same publishable key, exposed to the browser for ClerkProvider / <SignUp>/<SignIn>.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Svix signing secret for /api/auth/clerk/webhook. Copy the per-endpoint secret from the
# Clerk dashboard (dev secret locally, prod secret in production).
CLERK_WEBHOOK_SIGNING_SECRET=

# --- Email: inbound webhook ---
# Shared secret enforced on Postmark's inbound webhook (X-Keeps-Webhook-Secret header).
# Mandatory in production (route returns 503 if unset, 401 on mismatch). Use 32+ chars in prod.
KEEPS_INBOUND_WEBHOOK_SECRET=

# --- Email: outbound (Postmark) ---
# Postmark server token for live outbound sends.
# LEAVE UNSET IN LOCAL: when empty, the DevRecordingSender is used (records to outbound_emails,
# no live email). Set the Postmark live token only in production (sandbox token in Preview).
POSTMARK_SERVER_TOKEN=
# From address on outbound nudges/replies. Pilot uses the verified sender keeps@basicsoftware.ai.
POSTMARK_FROM_ADDRESS=keeps@basicsoftware.ai
# Full reply-to base address (local@domain) that nudge mailboxes plus-route onto:
# base "<hash>@inbound.postmarkapp.com" -> "<hash>+n_<nudgeId>@inbound.postmarkapp.com".
# Pilot decision (2026-06-12): keeps.ai is not purchased, so replies route to Postmark's
# generated inbound address. Replace the value below with that generated <hash> address.
POSTMARK_REPLY_TO_BASE=changeme-hash@inbound.postmarkapp.com
# Postmark message stream for outbound sends.
POSTMARK_MESSAGE_STREAM=outbound

# --- OpenAI (loop extraction) ---
# API key for live generateObject extraction. Optional locally/Preview; set in Production.
# When absent, the deterministic regex fallback runs (AR-8).
OPENAI_API_KEY=
# Model id used for extraction.
OPENAI_MODEL=gpt-5.1

# --- Inngest (workflows) ---
# Inngest Cloud event key for dispatching events.
# LEAVE UNSET IN LOCAL: when empty, the local Inngest dev server is used (gated by INNGEST_DEV).
# Set the Inngest Cloud key in Preview/Production.
INNGEST_EVENT_KEY=
# Inngest signing key for verifying inbound function invocations. Unset locally; set in cloud.
INNGEST_SIGNING_KEY=
# Set to 1 locally to route through the Inngest dev server. Leave unset in Preview/Production.
INNGEST_DEV=1
